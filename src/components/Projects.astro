---
import GitHub from "./icons/GitHub.astro";
import NextJS from "./icons/NextJS.astro";
import Tailwind from "./icons/Tailwind.astro";
import Link from "./icons/Link.astro";
import LinkButton from "./LinkButton.astro";
import ReactSVG from "./icons/ReactSVG.astro";
import Shadcnui from "./icons/Shadcnui.astro";
import Typescript from "./icons/Typescript.astro";
import Paypal from "./icons/Paypal.astro";

const TAGS = {
  PAYPAL: {
    name: "Paypal",
    class: "bg-[#002991] text-white",
    icon: Paypal,
  },
  TYPESCRIPT: {
    name: "Typescript",
    class: "bg-[#003159] text-white",
    icon: Typescript,
  },
  SHADCNUI: {
    name: "Shadcnui",
    class: "bg-[#003159] text-white",
    icon: Shadcnui,
  },
  REACTSVG: {
    name: "React",
    class: "bg-[#003159] text-white",
    icon: ReactSVG,
  },
  NEXT: {
    name: "Next.js",
    class: "bg-black text-white",
    icon: NextJS,
  },
  TAILWIND: {
    name: "Tailwind CSS",
    class: "bg-[#003159] text-white",
    icon: Tailwind,
  },
};

const PROJECTS = [
  {
    title: "Palette Generator - Generate your own color palette",
    description:
      "Genera tu propio paleta de colores con una interfaz amigable y sencilla.",
    link: "https://palette-generator-blue.vercel.app/",
    github: "https://github.com/omar15hr/palette-generator",
    image: "/projects/palette-generator.webp",
    tags: [TAGS.REACTSVG, TAGS.TAILWIND, TAGS.NEXT, TAGS.TYPESCRIPT],
  },
  {
    title: "OmarUI - A UI library for React",
    description:
      "Colección de componentes de React, creados desde cero con Next Js, Tailwind CSS y Typescript.",
    link: "https://omar-ui.vercel.app/",
    github: "https://github.com/omar15hr/omar-ui",
    image: "/projects/omarui.webp",
    tags: [TAGS.REACTSVG, TAGS.TAILWIND, TAGS.NEXT, TAGS.TYPESCRIPT],
  },
  {
    title: "Task Manager - A Trello clone",
    description:
      "Gestor de tareas, listas y proyectos. Creado desde cero con React y Tailwind CSS.",
    link: "https://task-manager-omarher.vercel.app/",
    github: "https://github.com/omar15hr/task-manager",
    image: "/projects/taskManager.webp",
    tags: [TAGS.REACTSVG, TAGS.TAILWIND, TAGS.SHADCNUI, TAGS.TYPESCRIPT],
  },
  {
    title: "Muscari Clothing - E-commerce of clothing",
    description:
      "E-commerce de ropa, cuenta con autenticación, envío de correos para recuperar contraseña y pasarela de pago con Paypal. Creado desde cero con Next.js, React y Tailwind CSS.",
    link: "https://muscari.vercel.app/",
    github: "https://github.com/omar15hr/Muscari",
    image: "/projects/muscari.webp",
    tags: [TAGS.NEXT, TAGS.TAILWIND, TAGS.TYPESCRIPT, TAGS.PAYPAL],
  },
  {
    title: "Background Snippets",
    description:
      "Colección de backgrounds para cualquier proyecto, solo copiar y pegar. Creada desde cero con React y Tailwind CSS.",
    link: "https://background-snippets-two.vercel.app/",
    github: "https://github.com/omar15hr/background-snippets",
    image: "/projects/backgroundSnippets.webp",
    tags: [TAGS.REACTSVG, TAGS.TAILWIND],
  },
];
---

<div class="flex flex-col gap-y-16">
  {
    PROJECTS.map(({ image, title, description, tags, link, github }) => (
      <article class="flex flex-col space-x-0 space-y-8 group md:flex-row md:space-x-8 md:space-y-0">
        <div class="w-full md:w-1/2">
          <div class="relative flex flex-col items-center col-span-6 row-span-5 gap-8 transition duration-500 ease-in-out transform shadow-xl overflow-clip rounded-xl sm:rounded-xl md:group-hover:-translate-y-1 md:group-hover:shadow-2xl lg:border lg:border-gray-800 lg:hover:border-gray-700 lg:hover:bg-gray-800/50">
            <img
              alt="Recién llegado vs 5 años en Nueva Zelanda"
              class="object-cover object-top w-full h-56 transition duration-500 sm:h-full md:scale-110 md:group-hover:scale-105"
              src={image}
            />
          </div>
        </div>

        <div class="w-full md:w-1/2 md:max-w-lg">
          <h3 class="text-2xl font-bold text-gray-800 dark:text-gray-100">
            {title}
          </h3>
          <div class="flex flex-wrap mt-2">
            <ul class="flex flex-row mb-2 gap-x-2">
              {tags.map((tag) => (
                <li>
                  <span
                    class={`flex gap-x-2 rounded-full text-xs ${tag.class} py-1 px-2 `}
                  >
                    <tag.icon class="size-4" />
                    {tag.name}
                  </span>
                </li>
              ))}
            </ul>

            <div class="mt-2 text-gray-700 dark:text-gray-400">
              {description}
            </div>
            <footer class="flex items-end justify-start mt-4 gap-x-4">
              {github && (
                <LinkButton href={github}>
                  <GitHub class="size-6" />
                  Code
                </LinkButton>
              )}
              {link && (
                <LinkButton href={link}>
                  <Link class="size-4" />
                  Preview
                </LinkButton>
              )}
            </footer>
          </div>
        </div>
      </article>
    ))
  }
</div>
